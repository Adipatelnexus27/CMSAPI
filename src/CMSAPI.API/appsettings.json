{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(LocalDb)\\MSSQLLocalDB;Database=CMS_ClaimManagement;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "CMSAPI",
    "Audience": "CMSClients",
    "Key": "ReplaceThisWithAStrongKeyAtLeast32Characters",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "FileStorage": {
    "RootPath": "storage"
  },
  "Email": {
    "FromAddress": "noreply@cms.local"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
